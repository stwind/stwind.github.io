---
layout: text.hbs
---
<article class="post">
    <header class="post-title">
        <h1><a data-name="{{name}}" href="/blog/{{name}}">{{title}}</a></h1>
        <div class="pubdate">{{formatDate time "%d %b %Y"}}</div>
    </header>
    <div class="post-body">
        {{#markdown}}
        {{> body}}
        {{/markdown}}
    </div>
</article>

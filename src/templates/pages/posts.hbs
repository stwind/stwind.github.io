---
section: posts
layout: grid-4-7.hbs
---
{{#each posts}}
<article class="post">
    <header>
        <h1 class="post-title"><a href="/posts/{{name}}">{{title}}</a></h1>
        <div class="pubdate">{{formatDate time "%d %b %Y"}}</div>
    </header>
    {{#markdown}}
    {{text}}
    {{/markdown}}
</article>
{{/each}}

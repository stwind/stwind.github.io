---
section: blog
layout: grid-4-7.hbs
---
{{#each posts}}
<article class="post">
    <header>
        <h1><a class="post-title" data-name="{{name}}" href="/{{../section}}/{{name}}">{{title}}</a></h1>
        <div class="pubdate">{{formatDate time "%d %b %Y"}}</div>
    </header>
    <div class="post-body">
        {{#markdown}}
        {{{text}}}
        {{/markdown}}
    </div>
</article>
{{/each}}

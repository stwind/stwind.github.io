---
layout: text.hbs
---
<div class="posts">
    {{#each posts}}
    <article class="post">
        <header class="post-title">
            <h1><a href="{{name}}">{{title}}</a></h1>
            <div class="pubdate">{{formatDate time "%d %b %Y"}}</div>
        </header>
        <div class="post-body">
            {{#markdown}}{{{excerpt text name}}}{{/markdown}}
        </div>
    </article>
    {{/each}}
</div>

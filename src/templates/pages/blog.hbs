---
section: blog
layout: text.hbs
---
<div class="posts">
    {{#each posts}}
    <article class="post">
        <header class="post-title">
            <h1><a data-name="{{name}}" href="/{{../section}}/{{name}}">{{title}}</a></h1>
            <div class="pubdate">{{formatDate time "%d %b %Y"}}</div>
        </header>
        <div class="post-body">
            {{#markdown}}
            {{{text}}}
            {{/markdown}}
        </div>
    </article>
    {{/each}}
</div>
